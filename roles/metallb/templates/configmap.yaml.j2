---
apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: default-pool
  namespace: {{ metallb_namespace }}
spec:
  addresses:
  - {{ metallb_ip_range_start }}-{{ metallb_ip_range_end }}
---
apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: default-l2
  namespace: {{ metallb_namespace }}
spec:
  ipAddressPools:
  - default-pool

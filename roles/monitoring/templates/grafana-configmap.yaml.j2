apiVersion: v1
kind: ConfigMap
metadata:
  name: grafana-config
  namespace: monitoring
data:
  grafana.ini: |
    [server]
    http_port = 3000
    root_url = https://{{ domain_name }}/grafana/
    serve_from_sub_path = true

    [security]
    admin_user = admin
    admin_password = {{ grafana_admin_password }}

    [auth.anonymous]
    enabled = false

    [users]
    allow_sign_up = false

    [log]
    mode = console
    level = info
